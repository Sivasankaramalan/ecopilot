---
---
<style>
  .calc { background: var(--sl-color-bg-sidebar); border: 1px solid var(--sl-color-hairline); border-radius: 8px; padding: 24px; margin: 24px 0; }
  .calc label { display: block; margin-bottom: 4px; font-size: 0.875rem; font-weight: 500; }
  .calc input, .calc select { width: 100%; padding: 6px 10px; border: 1px solid var(--sl-color-hairline); border-radius: 4px; background: var(--sl-color-bg); color: var(--sl-color-text); font-size: 0.9rem; margin-bottom: 16px; }
  .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .results { background: var(--sl-color-green-low, #d1fae5); border-radius: 8px; padding: 16px; margin-top: 16px; display: none; }
  .result-item { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--sl-color-hairline); }
  .result-item:last-child { border-bottom: none; font-weight: 700; }
  .result-val { color: #16a34a; font-weight: 600; }
  button.recalc { background: #22c55e; color: #fff; border: none; padding: 8px 20px; border-radius: 4px; cursor: pointer; font-size: 0.9rem; margin-top: 4px; }
  button.recalc:hover { background: #16a34a; }
</style>

<div class="calc">
  <div class="calc-row">
    <div>
      <label for="ep-devs">Developers on team</label>
      <input type="number" id="ep-devs" value="5" min="1" max="500" />
    </div>
    <div>
      <label for="ep-sessions">Agent sessions per dev per day</label>
      <input type="number" id="ep-sessions" value="8" min="1" max="100" />
    </div>
  </div>
  <div class="calc-row">
    <div>
      <label for="ep-followups">Avg follow-up messages per session (without EcoPilot)</label>
      <input type="number" id="ep-followups" value="3" min="0" max="20" />
    </div>
    <div>
      <label for="ep-model">Primary model tier</label>
      <select id="ep-model">
        <option value="0.33">GPT-4o mini (0.33×)</option>
        <option value="1" selected>GPT-4o standard (1×)</option>
        <option value="3">o3 / Claude premium (3×)</option>
      </select>
    </div>
  </div>
  <div class="calc-row">
    <div>
      <label for="ep-verbosity">% of prompts that are verbose</label>
      <input type="number" id="ep-verbosity" value="60" min="0" max="100" />
    </div>
    <div>
      <label for="ep-savings">Avg token savings per tightened prompt (%)</label>
      <input type="number" id="ep-savings" value="35" min="0" max="90" />
    </div>
  </div>
  <button class="recalc" id="ep-btn">Calculate savings</button>
  <div class="results" id="ep-results"></div>
</div>

<script>
  function epCalc() {
    var devs = +document.getElementById('ep-devs').value;
    var sessions = +document.getElementById('ep-sessions').value;
    var followups = +document.getElementById('ep-followups').value;
    var mult = +document.getElementById('ep-model').value;
    var verbPct = +document.getElementById('ep-verbosity').value / 100;
    var savPct = +document.getElementById('ep-savings').value / 100;
    var days = 22;
    var followupsAvoided = devs * sessions * followups * days;
    var hitlWeighted = Math.round(followupsAvoided * mult);
    var monthlyPrompts = devs * sessions * days;
    var tokensSaved = Math.round(monthlyPrompts * verbPct * 80 * savPct);
    var total = hitlWeighted + Math.round(tokensSaved * mult);
    var r = document.getElementById('ep-results');
    r.style.display = 'block';
    r.innerHTML =
      '<div class="result-item"><span>Follow-up messages avoided / month</span><span class="result-val">' + followupsAvoided.toLocaleString() + '</span></div>' +
      '<div class="result-item"><span>Weighted requests saved (HITL) / month</span><span class="result-val">' + hitlWeighted.toLocaleString() + '</span></div>' +
      '<div class="result-item"><span>Tokens saved by prompt hygiene / month</span><span class="result-val">' + tokensSaved.toLocaleString() + '</span></div>' +
      '<div class="result-item"><span>Total weighted premium-equivalent / month</span><span class="result-val">' + total.toLocaleString() + '</span></div>';
  }
  document.getElementById('ep-btn').addEventListener('click', epCalc);
  epCalc();
</script>
